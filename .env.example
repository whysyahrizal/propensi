# Django
SECRET_KEY=your-secret-key-here
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Database: set DATABASE_URL on hosted environments (e.g. Render).
# For local dev without PostgreSQL, leave DATABASE_URL out (defaults to sqlite db.sqlite3)
# or if .env has DATABASE_URL but the server is not running:
# DJANGO_USE_SQLITE=1

# POSTGRES (optional; can build DATABASE_URL or use in Docker)
POSTGRES_DB=siraga_db
POSTGRES_USER=siraga_user
POSTGRES_PASSWORD=siraga_password
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
